# ============================================================
#  Copy this file to ".env" and fill in your values.
#  ".env" is git-ignored — never commit real credentials.
# ============================================================

# Jackett API key — from the Jackett web UI (top-right corner)
# or jackett_config/Jackett/ServerConfig.json ("APIKey").
# Informational only: nothing in the stack reads this value (Jackett stores the
# real key in ServerConfig.json, and Lampa gets it directly). The installer just
# records the key it read here for your reference — you don't have to fill it in.
JACKETT_APIKEY=

# FlareSolverr endpoint (Cloudflare bypass for protected trackers).
# Default matches the docker-compose service name; change only if you
# run FlareSolverr elsewhere.
JACKETT_FLARESOLVERR_URL=http://flaresolverr:8191

# Search indexers (trackers) are added on demand from the live Jackett by the
# installer (install.sh / install.bat), so there are no tracker credentials
# to store here. Public indexers add instantly; login/captcha ones prompt you.

# FlareSolverr (Cloudflare bypass, headless Chrome — a few hundred MB RAM).
# 1 = run it (default), 0 = skip it (saves RAM on small boxes like a
# Raspberry Pi; you only lose Cloudflare-protected trackers such as 1337x).
# The installer asks and records the answer here; used on re-runs (repair).
ENABLE_FLARESOLVERR=1

# --- TorrServer tuning (applied by configure.ps1) ---
# Cache size in bytes held in RAM (2 GiB = 2147483648).
# Leave EMPTY for auto: a quarter of the host's RAM, clamped to
# 256 MiB .. 2 GiB — safe on a Raspberry Pi, full-size on a PC.
TORRSERVER_CACHE_SIZE=
# Max simultaneous P2P connections
TORRSERVER_CONN_LIMIT=1000
# Fixed port for INCOMING peer connections. Must match docker-compose.yml
# and be forwarded on your router to this PC. 0 = random (bad for speed).
TORRSERVER_PEER_PORT=42116
# Pinned TorrServer image tag (ghcr.io/yourok/torrserver). MatriX.142
# crashes under load (upstream issue #766) — bump when fixed.
TORRSERVER_VERSION=MatriX.141.10
# Keep torrent+cache alive this long (sec) after the player disconnects
# (e.g. long pause). 3600 = 1 hour of instant resume.
TORRSERVER_DISCONNECT_TIMEOUT=3600
# Preload buffer: % of the cache filled before playback starts. 10 = quick
# start, buffer keeps filling while you watch. Higher (e.g. 50) = smoother
# start on poorly-seeded torrents but a longer wait before play + more RAM.
TORRSERVER_PRELOAD=10

# --- Cloudflare WARP tunnel (optional; used by the "warp" service) ---
# Generate with wgcf (see README "WARP" section), then paste values here.
# Leave blank and remove the warp service if you don't use the tunnel.
WARP_PRIVATE_KEY=
WARP_ADDRESS_V4=172.16.0.2/32
