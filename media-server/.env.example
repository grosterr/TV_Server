# ============================================================
#  Copy this file to ".env" and fill in your values.
#  ".env" is git-ignored — never commit real credentials.
# ============================================================

# Jackett API key — from the Jackett web UI (top-right corner)
# or jackett_config/Jackett/ServerConfig.json ("APIKey").
JACKETT_APIKEY=

# --- Private tracker credentials (leave blank to skip a tracker) ---
TOLOKA_USER=
TOLOKA_PASS=

RUTRACKER_USER=
RUTRACKER_PASS=

# --- TorrServer tuning (applied by configure.ps1) ---
# Cache size in bytes held in RAM (2 GiB = 2147483648)
TORRSERVER_CACHE_SIZE=2147483648
# Max simultaneous P2P connections
TORRSERVER_CONN_LIMIT=1000
# Fixed port for INCOMING peer connections. Must match docker-compose.yml
# and be forwarded on your router to this PC. 0 = random (bad for speed).
TORRSERVER_PEER_PORT=42116
