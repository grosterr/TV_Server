# ============================================================
#  Copy this file to ".env" and fill in your values.
#  ".env" is git-ignored — never commit real credentials.
# ============================================================

# Jackett API key — from the Jackett web UI (top-right corner)
# or jackett_config/Jackett/ServerConfig.json ("APIKey").
JACKETT_APIKEY=

# FlareSolverr endpoint (Cloudflare bypass for protected trackers).
# Default matches the docker-compose service name; change only if you
# run FlareSolverr elsewhere.
JACKETT_FLARESOLVERR_URL=http://flaresolverr:8191

# --- Private tracker credentials (leave blank to skip a tracker) ---
TOLOKA_USER=
TOLOKA_PASS=

RUTRACKER_USER=
RUTRACKER_PASS=

# --- TorrServer tuning (applied by configure.ps1) ---
# Cache size in bytes held in RAM (2 GiB = 2147483648)
TORRSERVER_CACHE_SIZE=2147483648
# Max simultaneous P2P connections
TORRSERVER_CONN_LIMIT=1000
# Fixed port for INCOMING peer connections. Must match docker-compose.yml
# and be forwarded on your router to this PC. 0 = random (bad for speed).
TORRSERVER_PEER_PORT=42116
# Pinned TorrServer image tag (ghcr.io/yourok/torrserver). MatriX.142
# crashes under load (upstream issue #766) — bump when fixed.
TORRSERVER_VERSION=MatriX.141.10
# Keep torrent+cache alive this long (sec) after the player disconnects
# (e.g. long pause). 3600 = 1 hour of instant resume.
TORRSERVER_DISCONNECT_TIMEOUT=3600

# --- Cloudflare WARP tunnel (optional; used by the "warp" service) ---
# Generate with wgcf (see README "WARP" section), then paste values here.
# Leave blank and remove the warp service if you don't use the tunnel.
WARP_PRIVATE_KEY=
WARP_ADDRESS_V4=172.16.0.2/32
